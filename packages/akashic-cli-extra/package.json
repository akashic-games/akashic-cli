{
  "name": "@akashic/akashic-cli-extra",
  "version": "2.0.0",
  "description": "Extra tools of akashic-cli-xxx",
  "type": "module",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./lib/*": {
      "import": {
        "types": "./lib/*",
        "default": "./lib/*"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "akashic-cli-config": "./bin/akashic-cli-config.js",
    "akashic-cli-modify": "./bin/akashic-cli-modify.js",
    "akashic-cli-stat": "./bin/akashic-cli-stat.js"
  },
  "scripts": {
    "prepublish": "npm run clean && npm run build",
    "clean": "rimraf ./lib && rimraf ./spec/build",
    "build": "tsc -p ./",
    "test": "npm run test:vitest && npm run test:lint",
    "test:vitest": "vitest run",
    "test:lint": "eslint -c .eslintrc.cjs --fix \"./src/**/*.ts\""
  },
  "author": "DWANGO Co., Ltd.",
  "license": "MIT",
  "files": [
    "lib"
  ],
  "dependencies": {
    "@akashic/akashic-cli-commons": "1.0.0",
    "commander": "12.1.0",
    "ini": "5.0.0",
    "lodash": "4.17.21"
  },
  "devDependencies": {
    "@akashic/eslint-config": "2.1.0",
    "@types/ini": "4.1.1",
    "@types/lodash": "4.17.9",
    "@types/mock-fs": "4.13.4",
    "@types/node": "22.14.1",
    "@typescript-eslint/eslint-plugin": "8.30.1",
    "eslint": "9.25.0",
    "eslint-plugin-import": "2.29.1",
    "mock-fs": "5.2.0",
    "rimraf": "6.0.1",
    "typescript": "5.5.4",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "@akashic:registry": "https://registry.npmjs.org/"
  }
}
