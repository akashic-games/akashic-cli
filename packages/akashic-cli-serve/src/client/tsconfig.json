{
  "compilerOptions": {
    "target": "ES2020",
    "declaration": false,
    "lib": ["dom", "ES2020"],
    "types": ["vite/client"],
    "noImplicitAny": true,
    "module": "preserve",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "jsx": "react",
    "sourceMap": true,
    "noEmit": true,
    "noUnusedParameters": true,
    "experimentalDecorators": true,
    "useUnknownInCatchVariables": false,
    "isolatedModules": true,
    "skipLibCheck": true, // FIXME mobx-react@6.3.1 の型エラー回避に必要。mobx と併せて更新して外せないか確認する
    "strict": true
  },
  "include": [
    "./view/stories/**/*.tsx",
    "./akashic/AkashicGameViewWeb.d.ts",
    "./bootstrap.tsx",
    "./sandbox/bootstrap.tsx"
  ]
}
