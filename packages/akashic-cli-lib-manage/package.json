{
  "name": "@akashic/akashic-cli-lib-manage",
  "version": "2.0.0-next.1",
  "description": "npm command wrapper module for Akashic games",
  "type": "module",
  "scripts": {
    "prepublish": "npm run clean && npm run build",
    "clean": "rimraf ./lib && rimraf ./spec/build",
    "build": "tsc -p ./",
    "test": "npm run test:vitest && npm run test:lint",
    "test:vitest": "vitest run",
    "test:lint": "eslint -c .eslintrc.cjs --fix \"./src/**/*.ts\""
  },
  "author": "DWANGO Co., Ltd.",
  "license": "MIT",
  "bin": {
    "akashic-cli-install": "./bin/akashic-cli-install.js",
    "akashic-cli-uninstall": "./bin/akashic-cli-uninstall.js",
    "akashic-cli-update": "./bin/akashic-cli-update.js"
  },
  "files": [
    "lib"
  ],
  "devDependencies": {
    "@akashic/eslint-config": "2.1.0",
    "@akashic/game-configuration": "2.5.0",
    "@types/form-data": "2.5.0",
    "@types/mock-fs": "4.13.4",
    "@types/node": "22.13.14",
    "@types/tar": "6.1.13",
    "@typescript-eslint/eslint-plugin": "8.28.0",
    "eslint": "9.23.0",
    "eslint-plugin-import": "2.29.1",
    "mock-fs": "5.2.0",
    "rimraf": "6.0.1",
    "typescript": "5.6.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@akashic/akashic-cli-commons": "1.0.0-next.1",
    "commander": "12.1.0",
    "minipass": "7.1.2",
    "tar": "7.4.3"
  },
  "publishConfig": {
    "access": "public",
    "@akashic:registry": "https://registry.npmjs.org/"
  }
}
