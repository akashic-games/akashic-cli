{
  "name": "@akashic/akashic-cli",
  "version": "2.17.11",
  "description": "Command-line utility for akashic game development",
  "bin": {
    "akashic": "./bin/akashic"
  },
  "scripts": {
    "prepublish": "npm run clean && npm run build",
    "clean": "rimraf ./lib && rimraf ./spec/build",
    "start": "npm run build && node bin/run",
    "build": "tsc -p ./",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "npm run lint"
  },
  "author": "DWANGO Co., Ltd.",
  "license": "MIT",
  "files": [
    "README.md",
    "package.json",
    "bin",
    "lib"
  ],
  "dependencies": {
    "@akashic/akashic-cli-commons": "0.15.3",
    "@akashic/akashic-cli-export": "1.9.11",
    "@akashic/akashic-cli-extra": "1.7.6",
    "@akashic/akashic-cli-init": "1.15.6",
    "@akashic/akashic-cli-lib-manage": "1.9.5",
    "@akashic/akashic-cli-sandbox": "1.1.6",
    "@akashic/akashic-cli-scan": "0.17.5",
    "@akashic/akashic-cli-serve": "1.16.9",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@akashic/eslint-config": "1.1.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "eslint": "8.57.0",
    "eslint-plugin-import": "2.26.0",
    "eslint-plugin-jest": "28.8.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "@akashic:registry": "https://registry.npmjs.org/"
  }
}
